# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Opciones: ollama | openai | anthropic
# Por defecto usa Ollama (100% local, sin coste)
LLM_PROVIDER=ollama

# Ollama — modelo y URL (por defecto apunta a localhost)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b

# OpenAI — descomenta si usas GPT
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# Anthropic — descomenta si usas Claude
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Whisper (transcripción) ──────────────────────────────────────────────────
# device: cpu | cuda  (usa cuda si tienes GPU NVIDIA)
WHISPER_DEVICE=cpu
# compute_type: int8 | float16 | float32
# int8 → más rápido y ligero en CPU
# float16 → mejor calidad en GPU
WHISPER_COMPUTE_TYPE=int8

# ─── ChromaDB ─────────────────────────────────────────────────────────────────
# Con Docker Compose se sobreescribe automáticamente, no toques nada aquí
# Sin Docker: levanta ChromaDB con `chroma run --host localhost --port 8001`
CHROMA_HOST=localhost
CHROMA_PORT=8001

# Modo sin servidor (para tests o desarrollo rápido sin ChromaDB)
# CHROMA_EPHEMERAL=1
